    "repository": "https://github.com/Heximiao/repeat_plugin"
  },
  "host_application": {
    "min_version": "1.0.0",
    "max_version": "3.99.99"
  },
  "sdk": {
    "min_version": "2.5.1",
    "max_version": "2.99.99"
  },
  "plugin_type": "extension",
  "dependencies": [],
  "capabilities": ["send.text"],
  "i18n": {
    "default_locale": "zh-CN"
  }
